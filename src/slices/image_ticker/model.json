{
  "id": "image_ticker",
  "type": "SharedSlice",
  "name": "ImageTicker",
  "description": "Infinite scrolling ticker of images.",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Scrolling row of panels or sketches.",
      "primary": {
        "speed": {
          "type": "Number",
          "config": {
            "label": "Animation Speed (seconds)",
            "placeholder": "40"
          }
        },
        "reverse": {
          "type": "Boolean",
          "config": {
            "label": "Reverse direction",
            "default_value": false
          }
        },
        "background_color": {
          "type": "Text",
          "config": {
            "label": "Background color (CSS value)",
            "placeholder": "#0B0B0E"
          }
        },
        "background_image": {
          "type": "Image",
          "config": {
            "label": "Background image",
            "constraint": {},
            "thumbnails": []
          }
        }
      },
      "items": {
        "image": {
          "type": "Image",
          "config": {
            "label": "Image",
            "constraint": {},
            "thumbnails": []
          }
        },
        "show_badge": {
          "type": "Boolean",
          "config": {
            "label": "Show badge",
            "default_value": false
          }
        },
        "badge_text": {
          "type": "Text",
          "config": {
            "label": "Badge text",
            "placeholder": "Offer"
          }
        },
        "link": {
          "type": "Link",
          "config": {
            "label": "Image link",
            "placeholder": "",
            "select": null,
            "allowTargetBlank": true
          }
        }
      }
    }
  ]
}
