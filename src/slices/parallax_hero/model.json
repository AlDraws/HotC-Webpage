{
  "id": "parallax_hero",
  "type": "SharedSlice",
  "name": "ParallaxHero",
  "description": "Full-bleed hero with parallax background (image or video) + optional foreground PNG.",
  "variations": [{
    "id": "default",
    "name": "Default",
    "docURL": "...",
    "version": "initial",
    "description": "Hero with kicker, title, subtitle, CTAs, and parallax bg/fg.",
    "primary": {
      "kicker":     { "type": "Text",   "config": { "label": "Kicker" } },
      "title":      { "type": "StructuredText", "config": { "label": "Title", "single": "heading1" } },
      "subtitle":   { "type": "StructuredText", "config": { "label": "Subtitle", "multi": "paragraph" } },
      "bgImage":    { "type": "Image",  "config": { "label": "Background image" } },
      "bgVideo":    { "type": "Link",   "config": { "label": "Background video URL (mp4)", "select": "media" } },
      "foreground": { "type": "Image",  "config": { "label": "Foreground PNG (alpha)" } },
      "primaryCtaLabel":  { "type": "Text", "config": { "label": "Primary CTA label" } },
      "primaryCtaTarget": { "type": "Text", "config": { "label": "Primary CTA target (latest / episodes / store / lore)" } },
      "secondaryCtaLabel":  { "type": "Text", "config": { "label": "Secondary CTA label" } },
      "secondaryCtaTarget": { "type": "Text", "config": { "label": "Secondary CTA target" } },
      "size": { "type": "Select", "config": { "label": "Size", "options": ["md","lg"], "default_value": "lg" } }
    },
    "items": {}
  }]
}
