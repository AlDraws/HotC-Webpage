# Prismic — repository name (overrides slicemachine.config.json)
NEXT_PUBLIC_PRISMIC_ENVIRONMENT=

# Site URL — used for metadataBase, sitemap, and OG tags
# In Vercel this is set automatically; set it locally for accurate metadata previews
NEXT_PUBLIC_SITE_URL=https://example.com

# Prismic API tokens
PRISMIC_ACCESS_TOKEN=       # optional: for protected Content API access
PRISMIC_WRITE_TOKEN=        # required for prismic:translations:import
PRISMIC_REPOSITORY=         # optional: overrides repositoryName in slicemachine.config.json

# Prismic webhook secret — must match the secret configured in the Prismic dashboard
# Required for /api/revalidate to accept cache-invalidation webhooks
PRISMIC_WEBHOOK_SECRET=
