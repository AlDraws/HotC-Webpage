{
  "id": "page",
  "label": "Page",
  "repeatable": true,
  "status": true,
  "format": "page",
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID",
          "placeholder": ""
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Title",
          "placeholder": "",
          "single": "heading1",
          "allowTargetBlank": true
        }
      },
      "parent": {
        "type": "Link",
        "config": {
          "label": "Parent",
          "select": "document",
          "customtypes": ["page"]
        }
      },
        "slices": {
          "type": "Slices",
          "fieldset": "Slice Zone",
          "config": {
            "choices": {
              "hero": { "type": "SharedSlice" },
              "text_with_image": { "type": "SharedSlice" },
              "callout": { "type": "SharedSlice" },
              "quote": { "type": "SharedSlice" },
              "cta_block": { "type": "SharedSlice" },
              "newsletter_embed": { "type": "SharedSlice" },
              "image_gallery": { "type": "SharedSlice" },
              "image_cards": { "type": "SharedSlice" },
              "feature_grid": { "type": "SharedSlice" },
              "lore_section": { "type": "SharedSlice" },
              "external_support": { "type": "SharedSlice" },
              "image_ticker": { "type": "SharedSlice" },
              "parallax_hero": { "type": "SharedSlice" },
              "character_grid": { "type": "SharedSlice" },
              "image_full": { "type": "SharedSlice" }
            }
          }
        }
    },
    "SEO": {
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        }
      },
      "meta_description": {
        "type": "Text",
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        }
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "meta_image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "og_image_override": {
        "type": "Image",
        "config": {
          "label": "og_image_override",
          "constraint": {
            "width": 2400,
            "height": 1260
          },
          "thumbnails": []
        }
      },
      "noindex": {
        "type": "Boolean",
        "config": {
          "label": "noindex",
          "default_value": false,
          "placeholder_true": "true",
          "placeholder_false": "false"
        }
      }
    }
  }
}
