{
  "id": "episode",
  "label": "Episode",
  "format": "page",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid":         { "type": "UID",  "config": { "label": "Slug", "placeholder": "ch-12-the-first-heir" } },
      "number":      { "type": "Number", "config": { "label": "Chapter number" } },
      "title":       { "type": "StructuredText", "config": { "label": "Title", "single": "heading1" } },
      "synopsis":    { "type": "StructuredText", "config": { "label": "Synopsis", "multi": "paragraph" } },
      "publishedOn": { "type": "Date", "config": { "label": "Published on" } },
      "isNew":       { "type": "Boolean", "config": { "label": "Mark as new", "default_value": false } },
      "cover":       { "type": "Image", "config": { "label": "Cover (4:5)", "constraint": { "width": 1080, "height": 1350 } } },
      "pages": {
        "type": "Group",
        "config": {
          "label": "Pages (1080px wide strips)",
          "fields": {
            "image": { "type": "Image", "config": { "label": "Strip image (1080×N)", "constraint": { "width": 1080 } } },
            "alt":   { "type": "Text",  "config": { "label": "Alt text" } }
          }
        }
      }
    },
    "SEO": {
      "meta_title":       { "type": "Text", "config": { "label": "Meta title" } },
      "meta_description": { "type": "Text", "config": { "label": "Meta description" } }
    }
  }
}
