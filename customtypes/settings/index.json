{
  "id": "settings",
  "label": "Settings",
  "repeatable": false,
  "status": true,
  "format": "page",
  "json": {
    "Main": {
      "site_title": {
        "type": "StructuredText",
        "config": {
          "label": "site_title",
          "placeholder": "",
          "multi": "paragraph,preformatted,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl",
          "allowTargetBlank": true
        }
      },
      "brand": {
        "type": "Group",
        "config": {
          "label": "brand",
          "repeat": false,
          "fields": {
            "label": {
              "type": "Text",
              "config": {
                "label": "label",
                "placeholder": ""
              }
            },
            "link": {
              "type": "Link",
              "config": {
                "label": "link",
                "placeholder": "",
                "select": null,
                "allowTargetBlank": true,
                "allowText": true,
                "repeat": false
              }
            },
            "icon_image": {
              "type": "Image",
              "config": {
                "label": "icon_image",
                "constraint": {},
                "thumbnails": []
              }
            },
            "icon_alt_override": {
              "type": "Text",
              "config": {
                "label": "icon_alt_override",
                "placeholder": ""
              }
            },
            "icon_position": {
              "type": "Select",
              "config": {
                "label": "icon_position",
                "placeholder": "",
                "options": [
                  "left",
                  "right"
                ]
              }
            },
            "hide_label": {
              "type": "Boolean",
              "config": {
                "label": "hide_label",
                "default_value": false,
                "placeholder_true": "true",
                "placeholder_false": "false"
              }
            }
          }
        }
      },
      "header_logo": {
        "type": "Image",
        "config": {
          "label": "header_logo",
          "constraint": {},
          "thumbnails": []
        }
      },
      "footer_logo": {
        "type": "Image",
        "config": {
          "label": "footer_logo",
          "constraint": {},
          "thumbnails": []
        }
      },
      "og_default": {
        "type": "Image",
        "config": {
          "label": "og_default",
          "constraint": {
            "width": 1200,
            "height": 630
          },
          "thumbnails": []
        }
      },
      "footer_text": {
        "type": "StructuredText",
        "config": {
          "label": "footer_text",
          "placeholder": "",
          "multi": "paragraph",
          "allowTargetBlank": true
        }
      },
      "social_links": {
        "type": "Group",
        "config": {
          "label": "social_links",
          "repeat": true,
          "fields": {
            "label": {
              "type": "Text",
              "config": {
                "label": "label",
                "placeholder": ""
              }
            },
            "url": {
              "type": "Link",
              "config": {
                "label": "url",
                "placeholder": "",
                "select": null,
                "allowTargetBlank": true,
                "allowText": true,
                "repeat": false
              }
            },
            "icon_key": {
              "type": "Select",
              "config": {
                "label": "icon_key",
                "placeholder": "",
                "options": [
                  "X",
                  "instagram",
                  "tumblr",
                  "webtoon",
                  "tapas",
                  "youtube",
                  "tiktok",
                  "patreon",
                  "discord",
                  "github",
                  "other"
                ]
              }
            }
          }
        }
      },
      "tagline": {
        "type": "Text",
        "config": {
          "label": "tagline",
          "placeholder": "Website tagline"
        }
      },
      "copyright": {
        "type": "StructuredText",
        "config": {
          "label": "copyright",
          "placeholder": "Copyright text",
          "multi": "paragraph,strong,em,hyperlink"
        }
      },
      "site_by_text": {
        "type": "Text",
        "config": {
          "label": "site_by_text",
          "placeholder": "Site by text (e.g. Design & Dev by)"
        }
      },
      "site_by_logo": {
        "type": "Image",
        "config": {
          "label": "site_by_logo",
          "constraint": {},
          "thumbnails": []
        }
      },
      "site_by_link": {
        "type": "Link",
        "config": {
          "label": "site_by_link",
          "placeholder": "Link to creator's website",
          "select": null
        }
      },
      "prev_button_label": {
        "type": "Text",
        "config": {
          "label": "prev_button_label",
          "placeholder": "Previous Episode"
        }
      },
      "next_button_label": {
        "type": "Text",
        "config": {
          "label": "next_button_label",
          "placeholder": "Next Episode"
        }
      },
      "store_links": {
        "type": "Group",
        "config": {
          "label": "store_links",
          "repeat": true,
          "fields": {
            "label": {
              "type": "Text",
              "config": {
                "label": "label",
                "placeholder": ""
              }
            },
            "url": {
              "type": "Link",
              "config": {
                "label": "url",
                "placeholder": "",
                "select": null,
                "allowTargetBlank": true,
                "allowText": true,
                "repeat": false
              }
            }
          }
        }
      },
      "newsletter": {
        "type": "Group",
        "config": {
          "label": "newsletter",
          "repeat": true,
          "fields": {
            "provider": {
              "type": "Select",
              "config": {
                "label": "provider",
                "placeholder": "",
                "options": [
                  "Beehiiv",
                  "Mailchimp",
                  "Buttondown",
                  "Netlify"
                ]
              }
            },
            "embed": {
              "type": "Text",
              "config": {
                "label": "embed",
                "placeholder": ""
              }
            },
            "url": {
              "type": "Text",
              "config": {
                "label": "url",
                "placeholder": ""
              }
            },
            "cta_label": {
              "type": "Text",
              "config": {
                "label": "cta_label",
                "placeholder": ""
              }
            }
          }
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone"
      }
    },
    "SEO": {
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "meta_title",
          "placeholder": ""
        }
      },
      "meta_description": {
        "type": "StructuredText",
        "config": {
          "label": "meta_description",
          "placeholder": "",
          "multi": "paragraph,preformatted,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl",
          "allowTargetBlank": true
        }
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "meta_image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "noindex": {
        "type": "Boolean",
        "config": {
          "label": "noindex",
          "default_value": false,
          "placeholder_true": "true",
          "placeholder_false": "false"
        }
      }
    }
  }
}
