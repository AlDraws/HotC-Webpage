{
  "id": "character",
  "label": "character",
  "repeatable": true,
  "status": true,
  "format": "page",
  "json": {
    "Main": {
      "name": {
        "type": "Text",
        "config": {
          "label": "name",
          "placeholder": ""
        }
      },
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "is_visible": {
        "type": "Boolean",
        "config": {
          "label": "Visible on site",
          "default_value": true,
          "placeholder_true": "true",
          "placeholder_false": "false"
        }
      },
      "portrait": {
        "type": "Image",
        "config": {
          "label": "portrait",
          "constraint": {
            "width": 1200,
            "height": 1200
          },
          "thumbnails": []
        }
      },
      "role": {
        "type": "Select",
        "config": {
          "label": "role",
          "placeholder": "",
          "options": ["Protagonist", "Ally", "Antagonist", "Neutral", "Other"]
        }
      },
      "epithet": {
        "type": "Text",
        "config": {
          "label": "epithet",
          "placeholder": "e.g. The last to remember its names."
        }
      },
      "cover": {
        "type": "Image",
        "config": {
          "label": "cover",
          "constraint": {},
          "thumbnails": []
        }
      },
      "attributes": {
        "type": "Group",
        "config": {
          "label": "attributes",
          "repeat": true,
          "fields": {
            "label": {
              "type": "Text",
              "config": {
                "label": "label",
                "placeholder": "e.g. Lineage"
              }
            },
            "value": {
              "type": "Text",
              "config": {
                "label": "value",
                "placeholder": "e.g. Ember-tongue"
              }
            }
          }
        }
      },
      "short_bio": {
        "type": "StructuredText",
        "config": {
          "label": "short_bio",
          "placeholder": "",
          "multi": "paragraph,heading3,o-list-item",
          "allowTargetBlank": true
        }
      },
      "gallery": {
        "type": "Group",
        "config": {
          "label": "gallery",
          "repeat": true,
          "fields": {
            "image": {
              "type": "Image",
              "config": {
                "label": "image",
                "constraint": {},
                "thumbnails": []
              }
            },
            "caption": {
              "type": "Text",
              "config": {
                "label": "caption",
                "placeholder": ""
              }
            }
          }
        }
      },
      "relations": {
        "type": "Group",
        "config": {
          "label": "relations",
          "repeat": true,
          "fields": {
            "character_ref": {
              "type": "Link",
              "config": {
                "label": "character_ref",
                "select": "document",
                "customtypes": ["character"],
                "repeat": false
              }
            },
            "note": {
              "type": "Text",
              "config": {
                "label": "note",
                "placeholder": ""
              }
            }
          }
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "parallax_hero": {
              "type": "SharedSlice"
            },
            "text_with_image": {
              "type": "SharedSlice"
            },
            "quote": {
              "type": "SharedSlice"
            },
            "lore_section": {
              "type": "SharedSlice"
            },
            "youtube_embed": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO": {
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "meta_title",
          "placeholder": ""
        }
      },
      "meta_description": {
        "type": "StructuredText",
        "config": {
          "label": "meta_description",
          "placeholder": "",
          "multi": "paragraph,preformatted,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl",
          "allowTargetBlank": true
        }
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "meta_image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "noindex": {
        "type": "Boolean",
        "config": {
          "label": "noindex",
          "default_value": false,
          "placeholder_true": "true",
          "placeholder_false": "false"
        }
      }
    }
  }
}
