{
  "id": "lore_item",
  "label": "Lore item (Environment / Prop / Illustration)",
  "format": "page",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid":     { "type": "UID",  "config": { "label": "Slug" } },
      "kind":    { "type": "Select", "config": { "label": "Kind", "options": ["environment", "prop", "illustration"] } },
      "name":    { "type": "StructuredText", "config": { "label": "Name", "single": "heading1" } },
      "role":    { "type": "Text", "config": { "label": "Role / category tag" } },
      "epithet": { "type": "StructuredText", "config": { "label": "Epithet (1 line)", "single": "paragraph" } },
      "portrait":{ "type": "Image", "config": { "label": "Portrait" } },
      "cover":   { "type": "Image", "config": { "label": "Hero background" } },
      "body":    { "type": "StructuredText", "config": { "label": "Body", "multi": "paragraph" } },
      "gallery": { "type": "Group", "config": { "label": "Gallery", "fields": { "image": { "type": "Image", "config": { "label": "Image" } } } } }
    }
  }
}
