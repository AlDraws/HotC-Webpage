{
  "id": "lore_entry",
  "label": "lore_entry",
  "repeatable": true,
  "status": true,
  "format": "page",
  "json": {
    "Main": {
      "title": {
        "type": "Text",
        "config": {
          "label": "title",
          "placeholder": ""
        }
      },
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "cover": {
        "type": "Image",
        "config": {
          "label": "cover",
          "constraint": {
            "width": 1200,
            "height": 630
          },
          "thumbnails": []
        }
      },
      "category": {
        "type": "Select",
        "config": {
          "label": "category",
          "placeholder": "Environment, Prop, or Illustration",
          "options": [
            "Environment",
            "Prop",
            "Illustration",
            "History",
            "Culture"
          ]
        }
      },
      "epithet": {
        "type": "Text",
        "config": {
          "label": "epithet",
          "placeholder": "e.g. Built on the bones of the second pantheon."
        }
      },
      "role": {
        "type": "Text",
        "config": {
          "label": "role",
          "placeholder": "e.g. Town · South"
        }
      },
      "short_intro": {
        "type": "StructuredText",
        "config": {
          "label": "short_intro",
          "placeholder": "",
          "multi": "paragraph",
          "allowTargetBlank": true
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "text_with_image": {
              "type": "SharedSlice"
            },
            "image_gallery": {
              "type": "SharedSlice"
            },
            "quote": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO": {
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "meta_title",
          "placeholder": ""
        }
      },
      "meta_description": {
        "type": "StructuredText",
        "config": {
          "label": "meta_description",
          "placeholder": "",
          "multi": "paragraph,preformatted,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl",
          "allowTargetBlank": true
        }
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "meta_image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "noindex": {
        "type": "Boolean",
        "config": {
          "label": "noindex",
          "default_value": false,
          "placeholder_true": "true",
          "placeholder_false": "false"
        }
      }
    }
  }
}
