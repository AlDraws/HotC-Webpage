{
  "id": "settings",
  "label": "Site settings",
  "format": "custom",
  "repeatable": false,
  "status": true,
  "json": {
    "Main": {
      "siteTitle":  { "type": "Text", "config": { "label": "Site title" } },
      "tag":        { "type": "Text", "config": { "label": "Footer tagline" } },
      "logoLight":  { "type": "Image", "config": { "label": "Logo (light variant)" } },
      "socials": {
        "type": "Group",
        "config": {
          "label": "Social links",
          "fields": {
            "label": { "type": "Text", "config": { "label": "Label (Instagram / TikTok / Webtoon)" } },
            "url":   { "type": "Link", "config": { "label": "URL" } }
          }
        }
      },
      "navigation": {
        "type": "Group",
        "config": {
          "label": "Navigation",
          "fields": {
            "label": { "type": "Text", "config": { "label": "Label" } },
            "route": { "type": "Text", "config": { "label": "Route key (episodes / characters / lore / store / about)" } }
          }
        }
      }
    },
    "Brand": {
      "ember":   { "type": "Color", "config": { "label": "Ember (primary accent)" } },
      "cyan":    { "type": "Color", "config": { "label": "Cyan" } },
      "magenta": { "type": "Color", "config": { "label": "Magenta" } },
      "sfx":     { "type": "Color", "config": { "label": "SFX yellow" } },
      "ink":     { "type": "Color", "config": { "label": "Ink (line / text)" } },
      "paper":   { "type": "Color", "config": { "label": "Paper (warm cream)" } }
    }
  }
}
