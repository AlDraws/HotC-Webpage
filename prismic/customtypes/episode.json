{
  "id": "episode",
  "label": "Episode",
  "format": "page",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid":            { "type": "UID",    "config": { "label": "Slug", "placeholder": "ch-01-the-first-heir" } },
      "title":          { "type": "Text",   "config": { "label": "Title" } },
      "chapter_number": { "type": "Number", "config": { "label": "Chapter number" } },
      "publish_date":   { "type": "Date",   "config": { "label": "Publish date" } },
      "cover":          { "type": "Image",  "config": { "label": "Cover (4:5)", "constraint": { "width": 1080, "height": 1350 } } },
      "summary":        { "type": "StructuredText", "config": { "label": "Summary", "multi": "paragraph" } },
      "arc":            { "type": "Select", "config": { "label": "Arc", "options": ["Prologue", "Arc I", "Arc II", "Arc III", "Epilogue"], "default_value": "Prologue" } },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tags",
          "fields": {
            "tag": { "type": "Text", "config": { "label": "Tag" } }
          }
        }
      },
      "characters": {
        "type": "Group",
        "config": {
          "label": "Characters in episode",
          "fields": {
            "character_ref": { "type": "Link", "config": { "label": "Character", "select": "document", "customtypes": ["character"] } }
          }
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "episode_panel":     { "type": "SharedSlice" },
            "episode_divider":   { "type": "SharedSlice" },
            "episode_text_beat": { "type": "SharedSlice" },
            "external_support":  { "type": "SharedSlice" }
          }
        }
      }
    },
    "SEO": {
      "meta_title":       { "type": "Text",  "config": { "label": "Meta title" } },
      "meta_description": { "type": "StructuredText", "config": { "label": "Meta description", "multi": "paragraph" } },
      "meta_image":       { "type": "Image", "config": { "label": "OG image" } },
      "noindex":          { "type": "Boolean", "config": { "label": "No index", "default_value": false } }
    }
  }
}
